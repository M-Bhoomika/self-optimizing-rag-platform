# Docker Compose (Postgres service)
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=rag_platform

# Database (api/config/settings.py -> DatabaseSettings)
DATABASE_URL=postgresql://rag_user:rag_password@postgres:5432/rag_platform
DB_POOL_SIZE=5

# Auth (AuthSettings)
AUTH_REQUIRED=false
AUTH_HEADER_NAME=X-Tenant-Key

# Retrieval (RetrievalSettings)
RETRIEVAL_BACKEND=memory
RETRIEVAL_TOP_K=5
RETRIEVAL_SIMILARITY_THRESHOLD=0.0

# Embeddings (EmbeddingSettings)
EMBEDDING_PROVIDER=dummy
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=1536

# Cache (CacheSettings)
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300

# LLM (LLMSettings)
LLM_PROVIDER=local
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Evaluation (EvaluationSettings)
ENABLE_EVALUATION=true
FAITHFULNESS_THRESHOLD=0.7

# Application (ApplicationSettings)
LOG_LEVEL=INFO
MLFLOW_TRACKING_URI=http://mlflow:5000

# Worker / Celery (optional)
CELERY_ENABLED=false
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Storage (optional)
S3_BUCKET=
LOCAL_UPLOAD_DIR=./data/uploads

# Tracing (optional)
OTEL_TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Test/offline mode
SKIP_DB=false
